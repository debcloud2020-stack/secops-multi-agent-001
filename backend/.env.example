# Copy to backend/.env and fill in. NEVER commit a real .env (it is gitignored).

# Run fully offline with the LLM stub (default). Set to false to use OpenRouter.
MOCK_MODE=true

# OpenRouter (OpenAI-compatible)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=

# Two model tiers — put current OpenRouter model IDs here (do not hardcode in code).
LLM_MODEL_CHEAP=
LLM_MODEL_STRONG=

# Supervisor loop guard
MAX_SUPERVISOR_STEPS=12

# --- Phase 2: RAG + memory + guardrail ---
# Local HuggingFace embedding model (downloaded once to ~/.cache/huggingface).
EMBED_MODEL=BAAI/bge-small-en-v1.5
# LanceDB data dir (defaults to backend/.data/lancedb). Tests override this.
LANCEDB_DIR=
RAG_TOP_K=4
MEMORY_TOP_K=3
GUARDRAIL_ENABLED=true
GUARDRAIL_BLOCK=false

# Optional live-path settings (only used when MOCK_MODE=false)
AZURE_WORKSPACE_ID=
NVD_API_KEY=

# Synthetic data ingestion (Logs Ingestion API → SecOpsSynthetic_CL). Used by the
# 'synthetic' data_mode query and scripts/seed_synthetic.py. NOT secret.
DCE_ENDPOINT=
DCR_IMMUTABLE_ID=
DCR_STREAM_NAME=Custom-SecOpsSynthetic_CL

# --- Phase 3: API server ---
# Demo password required on every endpoint (Authorization: Bearer <DEMO_PASSWORD>).
# Leave empty and the gate fails closed (all requests rejected).
DEMO_PASSWORD=
API_HOST=127.0.0.1
API_PORT=8000
# Comma-separated browser origins allowed via CORS. Local default below; Phase 5b-2
# appends the deployed Static Web Apps origin (e.g. https://<swa>.azurestaticapps.net).
CORS_ORIGINS=http://localhost:3000

# --- Phase 5b-1: persistence ---
# When set, the LangGraph checkpointer uses Postgres (resumable runs survive restarts);
# unset = in-memory MemorySaver (default). In Azure, set this to the Postgres Flexible
# Server DSN on the Container App.
# POSTGRES_DSN=postgresql://postgres:postgres@localhost:5432/postgres
